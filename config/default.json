{
    "python_slug": "python3",
    "plugins": {
        "doctest": {
            "enabled": true,
            "extra_args": [
                "-std=c++17"
            ]
        },
        "clangtidy": {
            "enabled": true,
            "command": "clang-tidy",
            "config": null,
            "extra_args": [
                "-std=c++17",
                "-isysroot", 
                "/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk"
            ]
        },
        "metrixplusplus": {
            "enabled": true,
            "metrics": [
                "std.code.halstead.all",
                "std.code.maintindex.simple",
                "std.code.complexity.cyclomatic",
                "std.code.lines.code",
                "std.code.lines.comments",
                "std.code.ratio.comments"
            ]
        },
        "valgrind": {
            "enabled": true
        },
        "cppcheck": {
            "enabled": false,
            "command": "cppcheck"
        }
    }
}